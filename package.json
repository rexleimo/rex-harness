{
  "name": "@rexleimo/rex-harness",
  "version": "0.4.3",
  "description": "Standalone evidence-driven workflow control plane for coding agents",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rexleimo/rex-harness.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "docs/",
    "skill-sources/",
    "src/",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=24 <25"
  },
  "exports": {
    ".": "./src/index.mjs"
  },
  "bin": {
    "rex-harness": "./bin/rex-harness.mjs"
  },
  "scripts": {
    "test": "node --test tests/**/*.test.mjs",
    "test:contract": "node --test tests/contract/*.test.mjs",
    "test:scenarios": "node --test tests/scenarios/*.test.mjs",
    "test:architecture": "node --test tests/architecture/*.test.mjs",
    "test:skills": "node --test tests/skills/*.test.mjs",
    "doctor": "node bin/rex-harness.mjs doctor"
  }
}
